# Primary data pipeline — OPERATIONAL SECURITY
# Never hardcode the value of this variable anywhere in the codebase
CANNASPY_PRIMARY_API_HOST=

# Database (Supabase)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cache / Queue
REDIS_URL=redis://localhost:6379

# Auth (Clerk)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
VITE_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Billing (Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# AI (Anthropic)
ANTHROPIC_API_KEY=

# Data Collection
GOOGLE_PLACES_API_KEY=

# Email (Resend)
RESEND_API_KEY=

# Internal sales alerts (block cancellation — founder only, never customer-facing)
SALES_ALERT_EMAIL=

# Storage (AWS S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-west-2

# Monitoring (Sentry)
SENTRY_DSN=                   # API error tracking — get from sentry.io/settings/projects
VITE_SENTRY_DSN=              # Frontend error tracking (same or different DSN)

# App
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
VITE_API_URL=               # leave blank for dev (Vite proxy handles it); in production set to: https://your-api.railway.app
